# AI Agent Skills canonical environment template
# Copy to ~/VSCodespace/.env (or another local .env file) and fill in real values.
# This file is safe to commit because it contains names and defaults only.
# Never commit real credentials.

# ============================================================
# GITHUB / REPOSITORY AUTOMATION
# Shared across MCP sync, local tooling, and repo bootstrap.
# ============================================================
GITHUB_MCP_PAT=
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_COPILOT_API_KEY=

# ============================================================
# AI PROVIDERS
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_API_BASE=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
BRAVE_API_KEY=
CONTEXT7_API_KEY=
ZAI_API_KEY=
ZAI_BASE_URL=
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================================
# AZURE
# ============================================================
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_POSTGRES_CONNECTION_STRING=
CLAUDE_AZURE_PATH=

# ============================================================
# CLOUDFLARE
# ============================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=
CLOUDFLARE_ZONE_IDS=
CLOUDFLARE_WORKERS_SUBDOMAIN=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_KV_PREVIEW_NAMESPACE_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_DATABASE_NAME=
CLOUDFLARE_PAGES_PROJECT_NAME=
CLOUDFLARE_AI_DEFAULT_MODEL=@cf/meta/llama-3-8b-instruct
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_TEAM_NAME=

# ============================================================
# ATLASSIAN
# ============================================================
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_BASE_URL=
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
ATLASSIAN_APP_KEY=
ATLASSIAN_SHARED_SECRET=
JIRA_BASE_URL=
JIRA_DEFAULT_PROJECT=
JIRA_ACCOUNT_ID=
CONFLUENCE_BASE_URL=
CONFLUENCE_DEFAULT_SPACE=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=
STATUSPAGE_API_KEY=
STATUSPAGE_PAGE_ID=

# ============================================================
# DATABASES / DATA PLATFORMS
# ============================================================
SUPABASE_ACCESS_TOKEN=
SUPABASE_URL=
SUPABASE_API_KEY=
NEON_API_TOKEN=
COCKROACHDB_CLUSTER_ID=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHUNK_SIZE_BYTES=2048
CHUNK_OVERLAP_RATIO=0.5
MAX_REQUESTS_PER_MINUTE=200
MAX_TOKENS_PER_MINUTE=150000
SQLITE_DB_PATH=index_metadata.db

# ============================================================
# N8N / AUTOMATION
# ============================================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
N8N_USER_MANAGEMENT_JWT_SECRET=
N8N_ENCRYPTION_KEY=
DB_TYPE=sqlite
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SCHEMA=public
DB_POSTGRESDB_SSL_ENABLED=false
DB_MYSQLDB_HOST=localhost
DB_MYSQLDB_PORT=3306
DB_MYSQLDB_DATABASE=n8n
DB_MYSQLDB_USER=
DB_MYSQLDB_PASSWORD=
QUEUE_BULL_REDIS_HOST=localhost
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=
QUEUE_BULL_REDIS_DB=0
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=
N8N_SMTP_PORT=465
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console
N8N_LOG_FILE_LOCATION=/home/node/.n8n/logs/n8n.log

# ============================================================
# INTEGRATIONS / WORKFLOWS
# ============================================================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
NOTION_API_KEY=
AIRTABLE_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ============================================================
# LOCAL PATHS / MACHINE-SPECIFIC DEFAULTS
# These usually stay local and are not mirrored to GitHub repos.
# ============================================================
FILESYSTEM_ALLOWED_PATH=
WORKSPACE_PATH=./workspace
ONEDRIVE_PATH=
GOOGLE_DRIVE_PATH=
LOCAL_PATHS=
LOG_LEVEL=info
