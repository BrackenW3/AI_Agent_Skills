
[
  // ════════════════════════════════════════════════════════════════════════════
  //  VSCODE KEYBINDINGS · Solo Dev Workflow (Windows + macOS)
  //  Note: keybindings.json supports comments (JSONC)
  // ════════════════════════════════════════════════════════════════════════════

  // ───────────────────────────────────────────────────────────────────────────
  // FORMAT / FIX / IMPORTS
  // ───────────────────────────────────────────────────────────────────────────

  // Format document (your preferred chord)
  {
    "key": "ctrl+alt+l",
    "command": "editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly"
  },

  // Format selection
  {
    "key": "ctrl+k ctrl+f",
    "command": "editor.action.formatSelection",
    "when": "editorHasDocumentSelectionFormattingProvider && editorTextFocus && !editorReadonly && editorHasSelection"
  },

  // Organize imports (kept on ctrl+alt+o to avoid ctrl+shift+o symbol collision)
  {
    "key": "ctrl+alt+o",
    "command": "editor.action.organizeImports",
    "when": "editorTextFocus && !editorReadonly"
  },

  // Fix all auto-fixable actions (ESLint/Ruff/etc. depending on language)
  {
    "key": "ctrl+shift+.",
    "command": "editor.action.fixAll",
    "when": "editorTextFocus && !editorReadonly"
  },

  // Quick Fix (keep default muscle memory, but making explicit is okay)
  {
    "key": "ctrl+.",
    "command": "editor.action.quickFix",
    "when": "editorTextFocus && !editorReadonly"
  },

  // ───────────────────────────────────────────────────────────────────────────
  // FILES / SAVE
  // ───────────────────────────────────────────────────────────────────────────

  // Save All (context-safe: only when SCM view isn't active)
  {
    "key": "ctrl+alt+s",
    "command": "workbench.action.files.saveAll",
    "when": "!scmViewletVisible && !terminalFocus"
  },

  // ───────────────────────────────────────────────────────────────────────────
  // NAVIGATION
  // ───────────────────────────────────────────────────────────────────────────

  { "key": "alt+left",  "command": "workbench.action.navigateBack" },
  { "key": "alt+right", "command": "workbench.action.navigateForward" },

  {
    "key": "f12",
    "command": "editor.action.revealDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus"
  },
  {
    "key": "alt+f12",
    "command": "editor.action.peekDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus"
  },
  {
    "key": "shift+f12",
    "command": "editor.action.goToReferences",
    "when": "editorHasReferenceProvider && editorTextFocus"
  },

  { "key": "ctrl+p",       "command": "workbench.action.quickOpen" },
  { "key": "ctrl+shift+p", "command": "workbench.action.showCommands" },

  // Keep VS Code defaults:
  // ctrl+shift+o => Go to Symbol in File
  // ctrl+t       => Go to Symbol in Workspace

  // ───────────────────────────────────────────────────────────────────────────
  // EDITING (safe, common, low-conflict)
  // ───────────────────────────────────────────────────────────────────────────

  // Move lines
  {
    "key": "alt+up",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "alt+down",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly"
  },

  // Delete line
  {
    "key": "ctrl+shift+k",
    "command": "editor.action.deleteLines",
    "when": "editorTextFocus && !editorReadonly"
  },

  // Multi-cursor select all occurrences (kept)
  {
    "key": "ctrl+shift+l",
    "command": "editor.action.selectHighlights",
    "when": "editorTextFocus"
  },

  // Comment toggles
  {
    "key": "ctrl+/",
    "command": "editor.action.commentLine",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+shift+a",
    "command": "editor.action.blockComment",
    "when": "editorTextFocus && !editorReadonly"
  },

  // Rename symbol
  {
    "key": "f2",
    "command": "editor.action.rename",
    "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
  },

  // Suggestions / hints
  { "key": "ctrl+space",       "command": "editor.action.triggerSuggest", "when": "editorTextFocus" },
  { "key": "ctrl+shift+space", "command": "editor.action.triggerParameterHints", "when": "editorTextFocus" },

  // Expand selection
  { "key": "ctrl+shift+right", "command": "editor.action.smartSelect.expand", "when": "editorTextFocus" },

  // Join lines (note: ctrl+j is often "Toggle Panel" by default; only keep if you like it)
  {
    "key": "ctrl+j",
    "command": "editor.action.joinLines",
    "when": "editorTextFocus && !editorReadonly"
  },

  // ───────────────────────────────────────────────────────────────────────────
  // TABS / SPLITS
  // ───────────────────────────────────────────────────────────────────────────

  { "key": "ctrl+tab",       "command": "workbench.action.nextEditor" },
  { "key": "ctrl+shift+tab", "command": "workbench.action.previousEditor" },
  { "key": "ctrl+w",         "command": "workbench.action.closeActiveEditor" },
  { "key": "ctrl+k ctrl+w",  "command": "workbench.action.closeAllEditors" },

  { "key": "ctrl+\\",        "command": "workbench.action.splitEditorRight" },
  { "key": "ctrl+shift+\\",  "command": "workbench.action.splitEditorDown" },

  { "key": "ctrl+1", "command": "workbench.action.focusFirstEditorGroup" },
  { "key": "ctrl+2", "command": "workbench.action.focusSecondEditorGroup" },
  { "key": "ctrl+3", "command": "workbench.action.focusThirdEditorGroup" },

  // ───────────────────────────────────────────────────────────────────────────
  // PANELS / SIDEBAR
  // ───────────────────────────────────────────────────────────────────────────

  // Terminal toggle (use the standard key for this)
  { "key": "ctrl+`", "command": "workbench.action.terminal.toggleTerminal" },

  // New terminal + split
  { "key": "ctrl+shift+`", "command": "workbench.action.terminal.new" },
  { "key": "ctrl+alt+`",   "command": "workbench.action.terminal.splitInActiveTerminal" },

  { "key": "ctrl+b",        "command": "workbench.action.toggleSidebarVisibility" },
  { "key": "ctrl+alt+b",    "command": "workbench.action.toggleAuxiliaryBar" },

  { "key": "ctrl+shift+e",  "command": "workbench.view.explorer" },
  { "key": "ctrl+shift+f",  "command": "workbench.action.findInFiles" },
  { "key": "ctrl+shift+g",  "command": "workbench.view.scm" },
  { "key": "ctrl+shift+d",  "command": "workbench.view.debug" },
  { "key": "ctrl+shift+x",  "command": "workbench.view.extensions" },
  { "key": "ctrl+shift+m",  "command": "workbench.actions.view.problems" },

  // Best practice: Toggle panel without stealing ctrl+j (since you use it for join lines)
  { "key": "ctrl+alt+j", "command": "workbench.action.togglePanel" },

  // ───────────────────────────────────────────────────────────────────────────
  // GIT (context aware)
  // ───────────────────────────────────────────────────────────────────────────

  // Stage file (only when SCM view visible)
  {
    "key": "ctrl+alt+s",
    "command": "git.stage",
    "when": "scmProvider == git && scmViewletVisible"
  },

  {
    "key": "ctrl+alt+c",
    "command": "git.commit",
    "when": "scmProvider == git"
  },
  {
    "key": "ctrl+alt+p",
    "command": "git.push",
    "when": "scmProvider == git"
  },
  {
    "key": "ctrl+alt+l",
    "command": "git.pull",
    "when": "scmProvider == git && scmViewletVisible"
  },

  // ───────────────────────────────────────────────────────────────────────────
  // TERMINAL PRODUCTIVITY
  // ───────────────────────────────────────────────────────────────────────────

  { "key": "ctrl+shift+delete", "command": "workbench.action.terminal.kill" },

  { "key": "ctrl+alt+down", "command": "workbench.action.terminal.focusNextPane",     "when": "terminalFocus" },
  { "key": "ctrl+alt+up",   "command": "workbench.action.terminal.focusPreviousPane", "when": "terminalFocus" },

  { "key": "ctrl+k", "command": "workbench.action.terminal.clear", "when": "terminalFocus" },

  // Run selected text in terminal
  { "key": "ctrl+alt+r", "command": "workbench.action.terminal.runSelectedText", "when": "editorTextFocus" },

  // ───────────────────────────────────────────────────────────────────────────
  // AI (Copilot)
  // ───────────────────────────────────────────────────────────────────────────

  // Copilot Chat (moved off ctrl+shift+i since you were using it for format)
  { "key": "ctrl+shift+i", "command": "workbench.panel.chat.view.copilot.focus" },

  // Inline Chat
  { "key": "ctrl+i", "command": "inlineChat.start", "when": "editorTextFocus" },

  // Accept/dismiss inline suggestion
  { "key": "tab",    "command": "editor.action.inlineSuggest.commit", "when": "inlineSuggestionVisible && !editorTabMovesFocus" },
  { "key": "escape", "command": "editor.action.inlineSuggest.hide",   "when": "inlineSuggestionVisible" },

  // ───────────────────────────────────────────────────────────────────────────
  // DEBUGGING
  // ───────────────────────────────────────────────────────────────────────────

  { "key": "f5",       "command": "workbench.action.debug.start",    "when": "!inDebugMode" },
  { "key": "f5",       "command": "workbench.action.debug.continue", "when": "inDebugMode" },
  { "key": "shift+f5", "command": "workbench.action.debug.stop",     "when": "inDebugMode" },

  { "key": "f9",       "command": "editor.debug.action.toggleBreakpoint", "when": "editorTextFocus" },
  { "key": "f10",      "command": "workbench.action.debug.stepOver",      "when": "inDebugMode" },
  { "key": "f11",      "command": "workbench.action.debug.stepInto",      "when": "inDebugMode" },
  { "key": "shift+f11","command": "workbench.action.debug.stepOut",       "when": "inDebugMode" },

  // ───────────────────────────────────────────────────────────────────────────
  // TESTING
  // ───────────────────────────────────────────────────────────────────────────

  { "key": "ctrl+alt+a", "command": "testing.runAll" },
  { "key": "ctrl+alt+n", "command": "testing.runAtCursor", "when": "editorTextFocus" },
  { "key": "ctrl+alt+e", "command": "workbench.view.testing.focus" },

  // ───────────────────────────────────────────────────────────────────────────
  // MISC PRODUCTIVITY
  // ───────────────────────────────────────────────────────────────────────────

  { "key": "ctrl+,",       "command": "workbench.action.openSettings" },
  { "key": "ctrl+shift+,", "command": "workbench.action.openSettingsJson" },
  { "key": "ctrl+k ctrl+s","command": "workbench.action.openGlobalKeybindings" },

  { "key": "ctrl+k z",     "command": "workbench.action.toggleZenMode" },

  // Reveal active file in OS (Explorer/Finder)
  { "key": "ctrl+k ctrl+r", "command": "revealFileInOS" },

  // Copy relative path (moved off ctrl+k ctrl+c to avoid comment conflicts)
  { "key": "ctrl+k ctrl+y", "command": "copyRelativeFilePath" },

  { "key": "ctrl+k ctrl+u", "command": "editor.action.transformToUppercase", "when": "editorTextFocus" },
  { "key": "ctrl+k ctrl+l", "command": "editor.action.transformToLowercase", "when": "editorTextFocus" },

  { "key": "alt+z", "command": "editor.action.toggleWordWrap" },

  { "key": "ctrl+k ctrl+0", "command": "editor.foldAll",   "when": "editorTextFocus" },
  { "key": "ctrl+k ctrl+j", "command": "editor.unfoldAll", "when": "editorTextFocus" },

  // ───────────────────────────────────────────────────────────────────────────
  // AI AGENTS — Quick Access
  // ───────────────────────────────────────────────────────────────────────────

  // Focus the secondary sidebar (right panel — GitHub, Copilot, GitLens live here)
  { "key": "ctrl+alt+g", "command": "workbench.action.focusAuxiliaryBar" },

  // Toggle secondary sidebar
  { "key": "ctrl+alt+b", "command": "workbench.action.toggleAuxiliaryBar" },

  // Open GitHub Pull Requests view in right panel
  { "key": "ctrl+alt+h", "command": "workbench.view.extension.github-pull-requests" },

  // GitLens — Open Git Graph
  { "key": "ctrl+alt+l", "command": "gitlens.showGraph",
    "when": "!editorHasDocumentFormattingProvider && !editorTextFocus" },

  // GitLens — File history for current file
  { "key": "ctrl+alt+f", "command": "gitlens.showFileHistoryView" },

  // GitLens — Toggle inline blame on current line
  { "key": "ctrl+alt+,", "command": "gitlens.toggleLineBlame", "when": "editorTextFocus" }
]
