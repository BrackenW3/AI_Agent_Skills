# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://api.openai.com/v1
AZURE_OPENAI_API_VERSION=2024-02-15-preview
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your-api-key-here

# Indexing Configuration
CHUNK_SIZE_BYTES=2048
CHUNK_OVERLAP_RATIO=0.5

# Directory Paths (comma-separated for LOCAL_PATHS)
ONEDRIVE_PATH=/path/to/onedrive
GOOGLE_DRIVE_PATH=/path/to/google/drive
LOCAL_PATHS=/path/to/local/dir1,/path/to/local/dir2

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=200
MAX_TOKENS_PER_MINUTE=150000

# Database
SQLITE_DB_PATH=index_metadata.db

# Logging
LOG_LEVEL=INFO
