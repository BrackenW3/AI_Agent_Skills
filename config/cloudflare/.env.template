# Cloudflare Environment Variables Template
# ----------------------------------------
# Copy this file to .env (gitignored) and fill in your values.
# NEVER commit the .env file with real credentials.
#
# Usage:
#   cp config/cloudflare/.env.template config/cloudflare/.env
#   # Edit config/cloudflare/.env with your real values
#
# Manage API tokens at: https://dash.cloudflare.com/profile/api-tokens

# ============================================================
# CLOUDFLARE ACCOUNT
# ============================================================
# Your Cloudflare account ID (found in the dashboard sidebar)
CLOUDFLARE_ACCOUNT_ID=

# Email address associated with your Cloudflare account
CLOUDFLARE_EMAIL=

# ============================================================
# API TOKENS (preferred over Global API Key)
# ============================================================
# Scoped API token — create at https://dash.cloudflare.com/profile/api-tokens
# Recommended scopes: Zone:Read, DNS:Edit, Cache Purge, Workers Scripts:Edit
CLOUDFLARE_API_TOKEN=

# Global API Key (legacy — use API tokens where possible)
CLOUDFLARE_GLOBAL_API_KEY=

# ============================================================
# ZONES / DOMAINS
# ============================================================
# Zone ID for your primary domain (found in the zone overview page)
CLOUDFLARE_ZONE_ID=

# Primary domain name managed by Cloudflare
CLOUDFLARE_ZONE_NAME=

# Additional zone IDs if managing multiple domains (comma-separated)
CLOUDFLARE_ZONE_IDS=

# ============================================================
# CLOUDFLARE WORKERS
# ============================================================
# Workers scripts deploy via Wrangler — set account ID above.
# Additional Workers-specific vars:
CLOUDFLARE_WORKERS_SUBDOMAIN=
# KV namespace IDs
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_KV_PREVIEW_NAMESPACE_ID=

# ============================================================
# CLOUDFLARE R2 (Object Storage)
# ============================================================
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=

# ============================================================
# CLOUDFLARE D1 (SQLite Database)
# ============================================================
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_DATABASE_NAME=

# ============================================================
# CLOUDFLARE PAGES
# ============================================================
CLOUDFLARE_PAGES_PROJECT_NAME=

# ============================================================
# CLOUDFLARE AI / WORKERS AI
# ============================================================
# Workers AI uses the same API token and Account ID above.
# Default model for Workers AI inference:
CLOUDFLARE_AI_DEFAULT_MODEL=@cf/meta/llama-3-8b-instruct

# ============================================================
# CLOUDFLARE ZERO TRUST / ACCESS
# ============================================================
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_TEAM_NAME=
