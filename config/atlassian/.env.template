# Atlassian Environment Variables Template
# ----------------------------------------
# Copy this file to .env (gitignored) and fill in your values.
# NEVER commit the .env file with real credentials.
#
# Usage:
#   cp config/atlassian/.env.template config/atlassian/.env
#   # Edit config/atlassian/.env with your real values
#
# Create your API token at: https://id.atlassian.com/manage-profile/security/api-tokens

# ============================================================
# ATLASSIAN ACCOUNT
# ============================================================
# The email address associated with your Atlassian account
ATLASSIAN_EMAIL=

# API token generated from https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=

# ============================================================
# JIRA
# ============================================================
# Your Jira Cloud base URL, e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=

# Jira project key(s) you work with most (comma-separated)
JIRA_DEFAULT_PROJECT=

# Jira user account ID (find in your profile settings)
JIRA_ACCOUNT_ID=

# ============================================================
# CONFLUENCE
# ============================================================
# Your Confluence Cloud base URL, e.g. https://yourcompany.atlassian.net/wiki
CONFLUENCE_BASE_URL=

# Default Confluence space key
CONFLUENCE_DEFAULT_SPACE=

# ============================================================
# ATLASSIAN ACCESS / ROVO (Enterprise)
# ============================================================
# OAuth 2.0 client credentials (for server-to-server integrations)
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=

# Atlassian Forge / Connect app variables
ATLASSIAN_APP_KEY=
ATLASSIAN_SHARED_SECRET=

# ============================================================
# BITBUCKET (Atlassian)
# ============================================================
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=

# ============================================================
# STATUSPAGE (Atlassian)
# ============================================================
STATUSPAGE_API_KEY=
STATUSPAGE_PAGE_ID=
