# VS Code Environment Variables Template
# ----------------------------------------
# Copy this file to .env (gitignored) and fill in your values.
# NEVER commit the .env file with real credentials.
#
# Usage:
#   cp config/vscode/.env.template config/vscode/.env
#   # Edit config/vscode/.env with your real values
#
# These variables configure AI extensions and integrations used inside VS Code.

# ============================================================
# GITHUB / COPILOT
# ============================================================
# Personal Access Token (PAT) — needs repo, copilot scopes
GITHUB_TOKEN=

# GitHub username
GITHUB_USERNAME=

# GitHub Copilot API key (if using Copilot API directly)
GITHUB_COPILOT_API_KEY=

# ============================================================
# OPENAI
# ============================================================
OPENAI_API_KEY=
OPENAI_ORG_ID=
# Optional: override the default API base URL (e.g. for Azure OpenAI)
OPENAI_API_BASE=

# ============================================================
# ANTHROPIC / CLAUDE
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# GOOGLE / GEMINI
# ============================================================
GEMINI_API_KEY=
GOOGLE_API_KEY=
# Google Cloud project (for Vertex AI)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1

# ============================================================
# MISTRAL AI
# ============================================================
MISTRAL_API_KEY=

# ============================================================
# OLLAMA (local LLM)
# ============================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================================
# ZAI
# ============================================================
ZAI_API_KEY=
ZAI_BASE_URL=

# ============================================================
# AZURE OPENAI (if using Azure instead of OpenAI directly)
# ============================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================================
# HUGGING FACE
# ============================================================
HUGGINGFACE_API_KEY=

# ============================================================
# GENERAL / MISC
# ============================================================
# Log level: debug | info | warn | error
LOG_LEVEL=info
