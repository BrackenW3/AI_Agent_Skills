# n8n Environment Variables Template
# ----------------------------------------
# Copy this file to .env (gitignored) and fill in your values.
# NEVER commit the .env file with real credentials.
#
# Usage:
#   cp config/n8n/.env.template config/n8n/.env
#   # Edit config/n8n/.env with your real values
#
# Reference: https://docs.n8n.io/hosting/configuration/environment-variables/

# ============================================================
# CORE SERVER
# ============================================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# Public-facing URL used for webhooks
WEBHOOK_URL=http://localhost:5678/

# ============================================================
# AUTHENTICATION
# ============================================================
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# JWT secret for user management
N8N_USER_MANAGEMENT_JWT_SECRET=

# ============================================================
# ENCRYPTION
# ============================================================
# Secret used to encrypt credentials stored in the database
N8N_ENCRYPTION_KEY=

# ============================================================
# DATABASE
# ============================================================
# Options: sqlite | postgresdb | mysqldb | mariadb
DB_TYPE=sqlite

# PostgreSQL (if DB_TYPE=postgresdb)
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SCHEMA=public
DB_POSTGRESDB_SSL_ENABLED=false

# MySQL / MariaDB (if DB_TYPE=mysqldb or mariadb)
DB_MYSQLDB_HOST=localhost
DB_MYSQLDB_PORT=3306
DB_MYSQLDB_DATABASE=n8n
DB_MYSQLDB_USER=
DB_MYSQLDB_PASSWORD=

# ============================================================
# QUEUE / REDIS (for worker mode)
# ============================================================
QUEUE_BULL_REDIS_HOST=localhost
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=
QUEUE_BULL_REDIS_DB=0

# ============================================================
# EMAIL (SMTP)
# ============================================================
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=
N8N_SMTP_PORT=465
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=

# ============================================================
# AI / LLM INTEGRATIONS (used in n8n AI nodes)
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ============================================================
# THIRD-PARTY SERVICE CREDENTIALS (used in n8n workflows)
# ============================================================

# GitHub
GITHUB_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Atlassian (Jira / Confluence)
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=
ATLASSIAN_BASE_URL=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Google
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Microsoft / Azure
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Notion
NOTION_API_KEY=

# Airtable
AIRTABLE_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ============================================================
# LOGGING & DIAGNOSTICS
# ============================================================
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console
# Comma-separated: console,file
N8N_LOG_FILE_LOCATION=/home/node/.n8n/logs/n8n.log
