# Docker / CI environment variables
# Copy to .env and fill values, or pass via CI secrets

# Required
ANTHROPIC_API_KEY=
GITHUB_MCP_PAT=

# Recommended
CONTEXT7_API_KEY=
PERPLEXITY_API_KEY=

# Workspace mount path (host path to mount as /workspace)
WORKSPACE_PATH=./workspace

# Optional
XAI_API_KEY=
ZAI_API_KEY=
OPENAI_API_KEY=
