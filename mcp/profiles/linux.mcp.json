{
  "$comment": "Linux / WSL2 profile — standard dev MCPs, no Windows-specific servers. Applied by sync.sh --profile linux",
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_MCP_PAT}",
        "GITHUB_TOKEN": "${GITHUB_MCP_PAT}"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${FILESYSTEM_ALLOWED_PATH}"],
      "env": { "FILESYSTEM_ALLOWED_PATH": "${FILESYSTEM_ALLOWED_PATH}" }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": { "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}" }
    },
    "perplexity": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "perplexity-mcp"],
      "env": { "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}" }
    },
    "grok": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-xai-grok"],
      "env": { "XAI_API_KEY": "${XAI_API_KEY}" }
    }
  }
}
