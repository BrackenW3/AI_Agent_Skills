# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------------------------------
# SECRETS & CREDENTIALS — never commit actual env files
# -------------------------------------------------------
# local env files (actual values — always gitignored)
.env
.env.local
.env*.local
*.env

# Specific config env files (keep .env.template files, ignore filled-in .env files)
config/vscode/.env
config/n8n/.env
config/atlassian/.env
config/cloudflare/.env

# SSH private keys — never commit these
ssh-keys/
*_ed25519
*_rsa
*_ecdsa
id_ed25519
id_rsa
!*.pub

# API keys and secrets
*.key
*.secret
*_secret*
*_token*
secrets.json
secrets.yaml
secrets.yml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/

# OS files
Thumbs.db

.tmp.driveupload/
scripts/vector-search/index_metadata.db
scripts/vector-search/nppBackup/
reports/
scripts/auto-configure-mcp.ps1
scripts/laptop-full-setup.ps1
